<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="NXG.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NXG"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════ -->
            <!--  NXG DARK THEME — VTRL-Inspired Palette   -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Brand Accent Colors -->
            <Color x:Key="NXGAccent">#A246D9</Color>
            <Color x:Key="NXGAccentBright">#B85CE6</Color>
            <Color x:Key="NXGAccentDark">#8A32C0</Color>
            <Color x:Key="NXGAccentDeep">#6B21A8</Color>

            <!-- Background Colors -->
            <Color x:Key="NXGVoid">#0A0A0F</Color>
            <Color x:Key="NXGPanel">#12121A</Color>
            <Color x:Key="NXGSurface">#1A1A26</Color>
            <Color x:Key="NXGElevated">#22222E</Color>

            <!-- Text Colors -->
            <Color x:Key="NXGTextWhite">#FFFFFF</Color>
            <Color x:Key="NXGTextInk">#B0B0C0</Color>
            <Color x:Key="NXGTextInkDim">#707085</Color>

            <!-- Semantic Colors -->
            <Color x:Key="NXGSuccess">#22C55E</Color>
            <Color x:Key="NXGCaution">#F59E0B</Color>
            <Color x:Key="NXGDanger">#EF4444</Color>

            <!-- Border -->
            <Color x:Key="NXGEdge">#20FFFFFF</Color>

            <!-- ═══════════════════════════════════════════ -->
            <!--  Custom Brushes (for StaticResource usage) -->
            <!-- ═══════════════════════════════════════════ -->

            <SolidColorBrush x:Key="NXGAccentBrush" Color="{StaticResource NXGAccent}" />
            <SolidColorBrush x:Key="NXGAccentBrightBrush" Color="{StaticResource NXGAccentBright}" />
            <SolidColorBrush x:Key="NXGAccentDarkBrush" Color="{StaticResource NXGAccentDark}" />
            <SolidColorBrush x:Key="NXGVoidBrush" Color="{StaticResource NXGVoid}" />
            <SolidColorBrush x:Key="NXGPanelBrush" Color="{StaticResource NXGPanel}" />
            <SolidColorBrush x:Key="NXGSurfaceBrush" Color="{StaticResource NXGSurface}" />
            <SolidColorBrush x:Key="NXGElevatedBrush" Color="{StaticResource NXGElevated}" />
            <SolidColorBrush x:Key="NXGCardBrush" Color="{StaticResource NXGPanel}" />
            <SolidColorBrush x:Key="NXGCardBorderBrush" Color="{StaticResource NXGEdge}" />
            <SolidColorBrush x:Key="NXGTextWhiteBrush" Color="{StaticResource NXGTextWhite}" />
            <SolidColorBrush x:Key="NXGInkBrush" Color="{StaticResource NXGTextInk}" />
            <SolidColorBrush x:Key="NXGInkDimBrush" Color="{StaticResource NXGTextInkDim}" />
            <SolidColorBrush x:Key="NXGSuccessBrush" Color="{StaticResource NXGSuccess}" />
            <SolidColorBrush x:Key="NXGCautionBrush" Color="{StaticResource NXGCaution}" />
            <SolidColorBrush x:Key="NXGDangerBrush" Color="{StaticResource NXGDanger}" />

            <!-- ═══════════════════════════════════════════ -->
            <!--  WinUI Theme Resource Overrides            -->
            <!--  These override the built-in dark theme    -->
            <!--  so all existing pages automatically get   -->
            <!--  the NXG color scheme.                    -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Application Background -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource NXGVoid}" />

            <!-- Card backgrounds -->
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource NXGPanel}" />
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{StaticResource NXGSurface}" />

            <!-- Card borders -->
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource NXGEdge}" />

            <!-- Text fills -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource NXGTextWhite}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource NXGTextInk}" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource NXGTextInkDim}" />

            <!-- Accent text -->
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{StaticResource NXGAccentBright}" />

            <!-- System fills for semantic coloring -->
            <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource NXGSuccess}" />
            <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource NXGCaution}" />
            <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource NXGDanger}" />
            <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="#30A246D9" />

            <!-- NavigationView Overrides -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource NXGVoid}" />
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource NXGPanel}" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{StaticResource NXGPanel}" />

            <!-- ListView / Control backgrounds -->
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource NXGVoid}" />
            <SolidColorBrush x:Key="LayerOnMicaBaseAltFillColorDefaultBrush" Color="{StaticResource NXGVoid}" />

            <!-- ToggleSwitch purple accent override -->
            <SolidColorBrush x:Key="ToggleSwitchFillOnBrush" Color="{StaticResource NXGAccent}" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOverBrush" Color="{StaticResource NXGAccentBright}" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPressedBrush" Color="{StaticResource NXGAccentDark}" />

            <!-- ProgressBar / ProgressRing purple accent -->
            <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="{StaticResource NXGAccent}" />
            <SolidColorBrush x:Key="ProgressRingForegroundThemeBrush" Color="{StaticResource NXGAccent}" />

            <!-- AccentButtonStyle overrides -->
            <SolidColorBrush x:Key="AccentButtonBackground" Color="{StaticResource NXGAccent}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="{StaticResource NXGAccentBright}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="{StaticResource NXGAccentDark}" />
            <SolidColorBrush x:Key="AccentButtonForeground" Color="{StaticResource NXGTextWhite}" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="{StaticResource NXGTextWhite}" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="{StaticResource NXGTextWhite}" />

            <!-- TextBox / ComboBox dark backgrounds -->
            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource NXGSurface}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource NXGElevated}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource NXGElevated}" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource NXGEdge}" />
            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource NXGSurface}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource NXGElevated}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource NXGEdge}" />

            <!-- ScrollBar track -->
            <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
