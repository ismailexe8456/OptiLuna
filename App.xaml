<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Dtrl.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dtrl"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════════════════════════════════ -->
            <!--  DTRL DARK THEME — VTRL-Inspired Palette   -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Brand Accent Colors -->
            <Color x:Key="DtrlAccent">#A246D9</Color>
            <Color x:Key="DtrlAccentBright">#B85CE6</Color>
            <Color x:Key="DtrlAccentDark">#8A32C0</Color>
            <Color x:Key="DtrlAccentDeep">#6B21A8</Color>

            <!-- Background Colors -->
            <Color x:Key="DtrlVoid">#0A0A0F</Color>
            <Color x:Key="DtrlPanel">#12121A</Color>
            <Color x:Key="DtrlSurface">#1A1A26</Color>
            <Color x:Key="DtrlElevated">#22222E</Color>

            <!-- Text Colors -->
            <Color x:Key="DtrlTextWhite">#FFFFFF</Color>
            <Color x:Key="DtrlTextInk">#B0B0C0</Color>
            <Color x:Key="DtrlTextInkDim">#707085</Color>

            <!-- Semantic Colors -->
            <Color x:Key="DtrlSuccess">#22C55E</Color>
            <Color x:Key="DtrlCaution">#F59E0B</Color>
            <Color x:Key="DtrlDanger">#EF4444</Color>

            <!-- Border -->
            <Color x:Key="DtrlEdge">#20FFFFFF</Color>

            <!-- ═══════════════════════════════════════════ -->
            <!--  Custom Brushes (for StaticResource usage) -->
            <!-- ═══════════════════════════════════════════ -->

            <SolidColorBrush x:Key="DtrlAccentBrush" Color="{StaticResource DtrlAccent}" />
            <SolidColorBrush x:Key="DtrlAccentBrightBrush" Color="{StaticResource DtrlAccentBright}" />
            <SolidColorBrush x:Key="DtrlAccentDarkBrush" Color="{StaticResource DtrlAccentDark}" />
            <SolidColorBrush x:Key="DtrlVoidBrush" Color="{StaticResource DtrlVoid}" />
            <SolidColorBrush x:Key="DtrlPanelBrush" Color="{StaticResource DtrlPanel}" />
            <SolidColorBrush x:Key="DtrlSurfaceBrush" Color="{StaticResource DtrlSurface}" />
            <SolidColorBrush x:Key="DtrlElevatedBrush" Color="{StaticResource DtrlElevated}" />
            <SolidColorBrush x:Key="DtrlCardBrush" Color="{StaticResource DtrlPanel}" />
            <SolidColorBrush x:Key="DtrlCardBorderBrush" Color="{StaticResource DtrlEdge}" />
            <SolidColorBrush x:Key="DtrlTextWhiteBrush" Color="{StaticResource DtrlTextWhite}" />
            <SolidColorBrush x:Key="DtrlInkBrush" Color="{StaticResource DtrlTextInk}" />
            <SolidColorBrush x:Key="DtrlInkDimBrush" Color="{StaticResource DtrlTextInkDim}" />
            <SolidColorBrush x:Key="DtrlSuccessBrush" Color="{StaticResource DtrlSuccess}" />
            <SolidColorBrush x:Key="DtrlCautionBrush" Color="{StaticResource DtrlCaution}" />
            <SolidColorBrush x:Key="DtrlDangerBrush" Color="{StaticResource DtrlDanger}" />

            <!-- ═══════════════════════════════════════════ -->
            <!--  WinUI Theme Resource Overrides            -->
            <!--  These override the built-in dark theme    -->
            <!--  so all existing pages automatically get   -->
            <!--  the DTRL color scheme.                    -->
            <!-- ═══════════════════════════════════════════ -->

            <!-- Application Background -->
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource DtrlVoid}" />

            <!-- Card backgrounds -->
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource DtrlPanel}" />
            <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{StaticResource DtrlSurface}" />

            <!-- Card borders -->
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource DtrlEdge}" />

            <!-- Text fills -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource DtrlTextWhite}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource DtrlTextInk}" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource DtrlTextInkDim}" />

            <!-- Accent text -->
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{StaticResource DtrlAccentBright}" />

            <!-- System fills for semantic coloring -->
            <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource DtrlSuccess}" />
            <SolidColorBrush x:Key="SystemFillColorCautionBrush" Color="{StaticResource DtrlCaution}" />
            <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource DtrlDanger}" />
            <SolidColorBrush x:Key="SystemFillColorNeutralBrush" Color="#20FFFFFF" />
            <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="#30A246D9" />

            <!-- NavigationView Overrides -->
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource DtrlVoid}" />
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource DtrlPanel}" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{StaticResource DtrlPanel}" />

            <!-- ListView / Control backgrounds -->
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource DtrlVoid}" />
            <SolidColorBrush x:Key="LayerOnMicaBaseAltFillColorDefaultBrush" Color="{StaticResource DtrlVoid}" />

            <!-- ToggleSwitch purple accent override -->
            <SolidColorBrush x:Key="ToggleSwitchFillOnBrush" Color="{StaticResource DtrlAccent}" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOverBrush" Color="{StaticResource DtrlAccentBright}" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPressedBrush" Color="{StaticResource DtrlAccentDark}" />

            <!-- ProgressBar / ProgressRing purple accent -->
            <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="{StaticResource DtrlAccent}" />
            <SolidColorBrush x:Key="ProgressRingForegroundThemeBrush" Color="{StaticResource DtrlAccent}" />

            <!-- AccentButtonStyle overrides -->
            <SolidColorBrush x:Key="AccentButtonBackground" Color="{StaticResource DtrlAccent}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="{StaticResource DtrlAccentBright}" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="{StaticResource DtrlAccentDark}" />
            <SolidColorBrush x:Key="AccentButtonForeground" Color="{StaticResource DtrlTextWhite}" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="{StaticResource DtrlTextWhite}" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="{StaticResource DtrlTextWhite}" />

            <!-- TextBox / ComboBox dark backgrounds -->
            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource DtrlSurface}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource DtrlElevated}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource DtrlElevated}" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource DtrlEdge}" />
            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource DtrlSurface}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource DtrlElevated}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource DtrlEdge}" />

            <!-- ScrollBar track -->
            <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
