<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dtrl.Views.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Dtrl.Views"
    xmlns:services="using:Dtrl.Services"
    xmlns:models="using:Dtrl.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="Windows System Specifications &amp; Logs" Style="{StaticResource TitleTextBlockStyle}" />
            <Button Content="Refresh Records" Command="{x:Bind ViewModel.LoadSystemDataCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right"/>
        </Grid>

        <Pivot Grid.Row="1">
            <!-- Tab 1: Boot log history -->
            <PivotItem Header="Startup Logs">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Boot Analyzer" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="Reads Event ID 100 diagnostics logs to track startup speeds in seconds." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                            <TextBlock Text="Optimizations like disabling unnecessary services and startup apps directly reduce this metric." Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <ListView ItemsSource="{x:Bind ViewModel.BootLogs, Mode=OneWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:BootTimeEntry">
                                    <Grid Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind DateText}" Style="{StaticResource BodyTextBlockStyle}"/>
                                        <!-- Boot time -->
                                        <TextBlock Grid.Column="1" Text="{x:Bind BootTimeText}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlSuccessBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- Tab 2: Runtimes -->
            <PivotItem Header="Runtime Roster">
                <ListView ItemsSource="{x:Bind ViewModel.Runtimes, Mode=OneWay}" Padding="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:RuntimeInfo">
                            <Grid Padding="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Version}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}" Margin="20,0"/>
                                <TextBlock Grid.Column="2" Text="Installed" Foreground="{StaticResource DtrlSuccessBrush}" Style="{StaticResource BodyStrongTextBlockStyle}" Visibility="{x:Bind InstalledVisibility, Mode=OneWay}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Tab 3: Running Services -->
            <PivotItem Header="Running Services">
                <ListView ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" Padding="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ServiceGridInfo">
                            <Border Margin="0,4" Padding="12" CornerRadius="10" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind DisplayName}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind ServiceName}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        <TextBlock Text="{x:Bind Description}" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                        <TextBlock Text="{x:Bind Status}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlSuccessBrush}"/>
                                        <TextBlock Text="{x:Bind StartupType}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Tab 4: Installed Drivers -->
            <PivotItem Header="Hardware Drivers">
                <ListView ItemsSource="{x:Bind ViewModel.Drivers, Mode=OneWay}" Padding="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DriverInfo">
                            <Border Margin="0,4" Padding="12" CornerRadius="10" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind DeviceName}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind FriendlyName}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        <TextBlock Text="{x:Bind Provider}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                        <TextBlock Text="{x:Bind DriverVersion}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind DateText}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <!-- Tab 5: Installed Programs -->
            <PivotItem Header="Installed Programs">
                <ListView ItemsSource="{x:Bind ViewModel.InstalledApps, Mode=OneWay}" Padding="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AppInfo">
                            <Border Margin="0,4" Padding="12" CornerRadius="10" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind Publisher}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                        <TextBlock Text="{x:Bind Version}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind InstallDate}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
