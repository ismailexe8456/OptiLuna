<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NXG.Views.PowerPlanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NXG.Views"
    xmlns:models="using:NXG.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Power Plan &amp; CPU Tweaks" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Tab Filters (Desktop / Laptop / Custom) -->
        <Pivot Grid.Row="1" x:Name="TabPivot" SelectionChanged="Pivot_SelectionChanged">
            <PivotItem Header="Desktop Profiles"/>
            <PivotItem Header="Laptop Profiles"/>
            <PivotItem Header="Custom Advanced"/>
        </Pivot>

        <!-- Main Granular Power Toggles -->
        <ListView
            Grid.Row="2"
            x:Name="PowerSettingsListView"
            ItemsSource="{x:Bind ViewModel.DisplayedSettings, Mode=OneWay}"
            SelectionMode="None"
            Padding="0,0,8,0">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Tweak">
                    <Border Margin="0,4" CornerRadius="10" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Applied indicator bar -->
                            <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,16,0" Background="{StaticResource NXGAccentBrush}" Visibility="{x:Bind AppliedVisibility, Mode=OneWay}"/>

                            <Grid Grid.Column="1" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource NXGTextWhiteBrush}"/>
                                        <Border CornerRadius="10" Padding="8,3" Background="{ThemeResource SystemFillColorNeutralBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind RiskText}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind EstimatedImpact}" Foreground="{StaticResource NXGAccentBrightBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="20,0">
                                    <TextBlock Text="Restart Required" Foreground="{StaticResource NXGCautionBrush}" Style="{StaticResource CaptionTextBlockStyle}" Visibility="{x:Bind RestartVisibility, Mode=OneWay}"/>
                                </StackPanel>

                                <ToggleSwitch
                                    Grid.Column="2"
                                    IsOn="{x:Bind IsApplied, Mode=OneWay}"
                                    Toggled="PowerToggle_Toggled"
                                    VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="3" CornerRadius="12" Padding="16" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Select a Preset:" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" Foreground="{StaticResource NXGInkBrush}"/>
                    <ComboBox ItemsSource="{x:Bind ViewModel.Presets}" SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}" Width="160" VerticalAlignment="Center"/>
                    <Button Content="Apply Preset" Command="{x:Bind ViewModel.ApplyPresetCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" CornerRadius="8" Padding="16,8"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Revert Tab Settings" Command="{x:Bind ViewModel.RevertAllCommand}" VerticalAlignment="Center" CornerRadius="8" Padding="16,8"/>
            </Grid>
        </Border>
    </Grid>
</Page>
