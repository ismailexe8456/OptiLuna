<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NXG.Views.StoragePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NXG.Views"
    xmlns:models="using:NXG.Models"
    xmlns:vm="using:NXG.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <TextBlock Text="Storage Cleaner &amp; Drive Mapping" Style="{StaticResource TitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <TextBox PlaceholderText="Scan path..." Text="{x:Bind ViewModel.ScanPath, Mode=TwoWay}" Width="250"/>
                <Button Content="Scan Directory" Command="{x:Bind ViewModel.ScanTreemapCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Main Body Pivots -->
        <Pivot Grid.Row="1">
            
            <!-- Tab 1: Cache Cleaners -->
            <PivotItem Header="System Caches">
                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.Row="0" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Temporary Folder Caches" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.TempSizeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                            </StackPanel>
                            <Button Content="Clean" Command="{x:Bind ViewModel.CleanCacheCommand}" CommandParameter="Temp" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="0" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Windows Update Download Cache" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.UpdateSizeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                            </StackPanel>
                            <Button Content="Clean" Command="{x:Bind ViewModel.CleanCacheCommand}" CommandParameter="Update" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="0" Grid.Row="1" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="DirectX Shader Cache" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.DirectXSizeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                            </StackPanel>
                            <Button Content="Clean" Command="{x:Bind ViewModel.CleanCacheCommand}" CommandParameter="DirectX" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Grid.Row="1" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="System Log Files" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.LogsSizeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                            </StackPanel>
                            <Button Content="Clean" Command="{x:Bind ViewModel.CleanCacheCommand}" CommandParameter="Logs" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Total Cleanable Disk Cache Space" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.TotalCleanableText, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource NXGAccentBrightBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="One-Click Deep Clean" Command="{x:Bind ViewModel.CleanAllCachesCommand}" Style="{StaticResource AccentButtonStyle}" FontWeight="Bold"/>
                                <Button Content="Empty Recycle Bin" Command="{x:Bind ViewModel.CleanCacheCommand}" CommandParameter="RecycleBin"/>
                                <Button Content="Refresh Sizes" Command="{x:Bind ViewModel.LoadCacheSizesCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- Tab 2: Disk Space Treemap -->
            <PivotItem Header="Visual Disk Map">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Treemap layout representing sizes of files/folders in chosen scan path:" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                    
                    <Border Grid.Row="1" CornerRadius="12" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                        <Canvas x:Name="TreemapCanvas" SizeChanged="TreemapCanvas_SizeChanged" Background="Transparent"/>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- Tab 3: Large File Finder -->
            <PivotItem Header="Large File Finder">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Scan Large Files" Command="{x:Bind ViewModel.ScanLargeFilesCommand}" Style="{StaticResource AccentButtonStyle}"/>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.LargeFiles, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DiskItem">
                                <Grid Padding="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind FilePath}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Large Size" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- Tab 4: Duplicate Finder -->
            <PivotItem Header="Duplicate Finder">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Scan for Duplicate Files" Command="{x:Bind ViewModel.ScanDuplicatesCommand}" Style="{StaticResource AccentButtonStyle}"/>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DuplicateGroups, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DuplicateGroup">
                                <StackPanel Spacing="6" Padding="0,10">
                                    <TextBlock Text="{x:Bind GroupName}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource NXGAccentBrightBrush}"/>
                                    <ItemsControl ItemsSource="{x:Bind Files}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:DiskItem">
                                                 <TextBlock Text="{x:Bind FilePath}" Style="{StaticResource CaptionTextBlockStyle}" Margin="12,2,0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Height="1" Background="{StaticResource NXGCardBorderBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
