<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dtrl.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Dtrl.Views"
    xmlns:models="using:Dtrl.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Controls -->
        <Grid Grid.Row="0">
            <TextBlock Text="Optimization Audit Logs" Style="{StaticResource TitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshLogsCommand}"/>
                <Button Content="Export JSON" Command="{x:Bind ViewModel.ExportJsonCommand}"/>
                <Button Content="Export CSV" Command="{x:Bind ViewModel.ExportCsvCommand}"/>
                <Button Content="Clear Logs" Command="{x:Bind ViewModel.ClearLogsCommand}" Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Main logs lists -->
        <Border Grid.Row="1" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
            <ListView ItemsSource="{x:Bind ViewModel.AuditLogs, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LogEntry">
                        <Grid Padding="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Timestamp -->
                            <TextBlock Grid.Column="0" Text="{x:Bind LogTimeText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                            
                            <!-- Level -->
                            <Border Grid.Column="1" HorizontalAlignment="Left" CornerRadius="4" Padding="6,2" Background="{ThemeResource SystemFillColorNeutralBrush}" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Level}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </Border>

                            <!-- Action -->
                            <TextBlock Grid.Column="2" Text="{x:Bind Action}" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>

                            <!-- Details -->
                            <TextBlock Grid.Column="3" Text="{x:Bind Details}" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Status Footer -->
        <Grid Grid.Row="2">
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" HorizontalAlignment="Right" Width="20" Height="20"/>
        </Grid>
    </Grid>
</Page>
