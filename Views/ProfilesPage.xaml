<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NXG.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NXG.Views"
    xmlns:models="using:NXG.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left List of Profiles -->
        <Border Grid.Column="0" CornerRadius="12" Padding="12" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Optimization Profiles" Style="{StaticResource SubtitleTextBlockStyle}" />

                <ListView 
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProfileModel">
                            <StackPanel Padding="4,8" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="Built-in Game Profile" Foreground="{StaticResource NXGInkBrush}" Style="{StaticResource CaptionTextBlockStyle}" Visibility="{x:Bind BuiltInVisibility, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="8">
                    <Button Content="Import Profile (.nxg)" Command="{x:Bind ViewModel.ImportProfileCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Profile Details Panel -->
        <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
            <Grid RowSpacing="16" Visibility="{x:Bind ViewModel.ProfilePanelVisibility, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Profile header info -->
                <Grid Grid.Row="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Name, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Description, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <Button Content="Apply Profile" Command="{x:Bind ViewModel.ApplySelectedProfileCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="20,10" CornerRadius="4"/>
                </Grid>

                <TextBlock Grid.Row="1" Text="Configured Tweaks Package Contents:" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,10,0,0"/>

                <!-- Scrollable list of tweaks contained in profile -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedProfileTweakNames, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource BodyTextBlockStyle}" Margin="0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer Operations -->
                <Grid Grid.Row="3">
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Export Profile" Command="{x:Bind ViewModel.ExportProfileCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
