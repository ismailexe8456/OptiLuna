<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dtrl.Views.RecoveryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Dtrl.Views"
    xmlns:services="using:Dtrl.Services"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recovery Center &amp; Restore Points" Style="{StaticResource TitleTextBlockStyle}" />

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Create Restore point settings -->
            <Border Grid.Column="0" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Safety Control Panel" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    
                    <TextBlock Text="Before modifying system parameters, DTRL attempts to create a Windows Restore Point. You can also create baseline checkpoints manually below." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}" TextWrapping="Wrap"/>
                    
                    <TextBox Header="Checkpoint Description" Text="{x:Bind ViewModel.NewRestorePointName, Mode=TwoWay}"/>
                    
                    <Button Content="Create Restore Point" Command="{x:Bind ViewModel.CreateRestorePointCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />

                    <Border Height="1" Background="{StaticResource DtrlCardBorderBrush}" Margin="0,10"/>
                    
                    <TextBlock Text="System Restore Status:" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="WMI Access Active. Restore protection enabled." Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlSuccessBrush}"/>
                </StackPanel>
            </Border>

            <!-- Checkpoints list -->
            <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="Available Windows Restore Points" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <Button Content="Refresh List" Command="{x:Bind ViewModel.LoadRestorePointsCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right"/>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RestorePoints, Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:RestorePointInfo">
                                <Border Margin="0,4" Padding="12" CornerRadius="10" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{x:Bind Description}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <TextBlock Text="{x:Bind CreatedAt}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind SequenceNumberText}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{StaticResource DtrlAccentBrightBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2">
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" HorizontalAlignment="Right" Width="20" Height="20"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
