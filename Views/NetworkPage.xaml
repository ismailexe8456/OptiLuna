<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dtrl.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Dtrl.Views"
    xmlns:services="using:Dtrl.Services"
    xmlns:models="using:Dtrl.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Network Optimizer &amp; Diagnostics" Style="{StaticResource TitleTextBlockStyle}" />

        <Pivot Grid.Row="1">
            
            <!-- Tab 1: DNS Benchmarking & Changer -->
            <PivotItem Header="DNS Benchmark &amp; Switcher">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- DNS Changer -->
                    <Border Grid.Column="0" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="DNS Server Changer" Style="{StaticResource SubtitleTextBlockStyle}" />
                            
                            <Button Content="Optimize Internet Speed" Command="{x:Bind ViewModel.OptimizeInternetCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" FontWeight="Bold"/>
                            <Border Height="1" Background="{StaticResource DtrlCardBorderBrush}" Margin="0,5"/>

                            <TextBlock Text="{x:Bind ViewModel.DnsStatusText, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlAccentBrightBrush}"/>
                            
                            <Button Content="Switch to Cloudflare (1.1.1.1)" Command="{x:Bind ViewModel.ChangeDnsCommand}" CommandParameter="Cloudflare" HorizontalAlignment="Stretch" />
                            <Button Content="Switch to Google DNS (8.8.8.8)" Command="{x:Bind ViewModel.ChangeDnsCommand}" CommandParameter="Google" HorizontalAlignment="Stretch" />
                            <Button Content="Switch to Quad9 (9.9.9.9)" Command="{x:Bind ViewModel.ChangeDnsCommand}" CommandParameter="Quad9" HorizontalAlignment="Stretch" />
                            <Button Content="Switch to OpenDNS" Command="{x:Bind ViewModel.ChangeDnsCommand}" CommandParameter="OpenDNS" HorizontalAlignment="Stretch" />

                            <Border Height="1" Background="{StaticResource DtrlCardBorderBrush}" Margin="0,10"/>
                            
                            <Button Content="Flush DNS Resolver Cache" Command="{x:Bind ViewModel.FlushDnsCommand}" HorizontalAlignment="Stretch" />
                            <Button Content="Reset Winsock Catalog" Command="{x:Bind ViewModel.RunWinsockResetCommand}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <!-- DNS Benchmarking -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <TextBlock Text="Provider Latency Benchmark" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <Button Content="Run Benchmark" Command="{x:Bind ViewModel.BenchmarkDnsCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right" />
                            </Grid>

                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DnsResults, Mode=OneWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:DnsBenchmarkResult">
                                        <Grid Padding="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{x:Bind ProviderName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind PrimaryIp}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}" />
                                            </StackPanel>
                                            <!-- Query times -->
                                            <TextBlock Grid.Column="1" Text="ms latency" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource DtrlInkBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind AverageQueryTimeMs}" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" Margin="10,0" Foreground="{StaticResource DtrlSuccessBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- Tab 2: Ping Diagnostics & Jitter -->
            <PivotItem Header="Diagnostics &amp; MTU">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Ping Test Configuration -->
                    <Border Grid.Column="0" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Ping Sweep &amp; MTU" Style="{StaticResource SubtitleTextBlockStyle}" />
                            
                            <TextBox Header="Ping Target Host / IP" Text="{x:Bind ViewModel.PingTarget, Mode=TwoWay}"/>
                            <Button Content="Test Latency &amp; Loss" Command="{x:Bind ViewModel.RunDiagnosticsCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />
                            
                            <Border Height="1" Background="{StaticResource DtrlCardBorderBrush}" Margin="0,10"/>
                            
                            <TextBlock Text="{x:Bind ViewModel.OptimalMtuText, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlAccentBrightBrush}"/>
                            <Button Content="Analyze optimal MTU size" Command="{x:Bind ViewModel.FindOptimalMtuCommand}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <!-- Ping Test Results -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Connection Diagnostic Statistics" Style="{StaticResource SubtitleTextBlockStyle}" />
                            
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" CornerRadius="10" Padding="12" Background="{StaticResource DtrlSurfaceBrush}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Average Latency" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.LatencyMs, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ms" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" CornerRadius="10" Padding="12" Background="{StaticResource DtrlSurfaceBrush}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Jitter Variance" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.JitterMs, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ms" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" CornerRadius="10" Padding="12" Background="{StaticResource DtrlSurfaceBrush}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Packet Loss" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}"/>
                                        <TextBlock Text="{x:Bind ViewModel.PacketLoss, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" Foreground="{StaticResource DtrlCautionBrush}"/>
                                        <TextBlock Text="%" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Spacing="6" Margin="0,10,0,0">
                                <TextBlock Text="Diagnostics Logs:" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <Border Padding="12" CornerRadius="4" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                    <TextBlock Text="{x:Bind ViewModel.DiagnosticMessage, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
