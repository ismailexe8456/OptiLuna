<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NXG.Views.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NXG.Views"
    xmlns:models="using:NXG.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Hardware Telemetry Monitor" Style="{StaticResource TitleTextBlockStyle}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- CPU & GPU detailed panel -->
                <Border Grid.Column="0" Grid.Row="0" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Processing Units (CPU &amp; GPU)" Style="{StaticResource SubtitleTextBlockStyle}" />
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="CPU Load" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Metrics.CpuUsage, Mode=OneWay}" Minimum="0" Maximum="100"/>
                            <TextBlock Text="{x:Bind ViewModel.CpuLoadText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="GPU Load" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Metrics.GpuUsage, Mode=OneWay}" Minimum="0" Maximum="100"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuLoadText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="VRAM Used" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Metrics.GpuVramUsed, Mode=OneWay}" Minimum="0" Maximum="{x:Bind ViewModel.Metrics.GpuVramTotal, Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind ViewModel.GpuVramText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Motherboard & RAM detailed panel -->
                <Border Grid.Column="1" Grid.Row="0" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Memory &amp; Motherboard" Style="{StaticResource SubtitleTextBlockStyle}" />
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Physical Memory (RAM)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Metrics.RamUsed, Mode=OneWay}" Minimum="0" Maximum="{x:Bind ViewModel.Metrics.RamTotal, Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind ViewModel.RamUsedText, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Motherboard Spec" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.Metrics.MotherboardName, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="BIOS Version" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.Metrics.BiosVersion, Mode=OneWay}" Style="{StaticResource BodyTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Storage health SMART statuses -->
                <Border Grid.Column="0" Grid.Row="1" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Storage Drive Health (SMART)" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Metrics.StorageDrives, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:StorageDriveInfo">
                                    <StackPanel Padding="0,6" Spacing="4">
                                        <Grid>
                                            <TextBlock Text="{x:Bind DeviceId}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <TextBlock Text="{x:Bind Interface}" HorizontalAlignment="Right" Foreground="{StaticResource NXGAccentBrightBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        </Grid>
                                        <TextBlock Text="{x:Bind Model}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}"/>
                                        <Grid>
                                            <TextBlock Text="{x:Bind SmartStatusMessage}" Foreground="{x:Bind SmartStatusBrush}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                            <TextBlock Text="{x:Bind TemperatureText}" Visibility="{x:Bind TemperatureVisibility}" HorizontalAlignment="Right" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource NXGInkDimBrush}"/>
                                        </Grid>
                                        <Border Height="1" Background="{StaticResource NXGCardBorderBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Laptop Battery health status -->
                <Border Grid.Column="1" Grid.Row="1" CornerRadius="12" Padding="20" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Power &amp; Battery State" Style="{StaticResource SubtitleTextBlockStyle}" />
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Battery Remaining Capacity" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Metrics.BatteryLevel, Mode=OneWay}" Minimum="0" Maximum="100"/>
                            <Grid>
                                <TextBlock Text="{x:Bind ViewModel.Metrics.BatteryStatus, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Battery Health" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Healthy (98% Wear Level)" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
