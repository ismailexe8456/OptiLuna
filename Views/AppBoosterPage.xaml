<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NXG.Views.AppBoosterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NXG.Views"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="App Booster" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource NXGTextWhiteBrush}"/>

        <!-- Explanatory header panel -->
        <Border Grid.Row="1" CornerRadius="12" Padding="24" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE701;" Foreground="{StaticResource NXGAccentBrush}" FontSize="24"/>
                    <TextBlock Text="Smart Priority App Booster" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{StaticResource NXGAccentBrightBrush}"/>
                </StackPanel>
                <TextBlock Text="App Booster optimizes processor thread scheduling cycles for active gaming processes and suspends low-priority background telemetry tasks, restoring performance instantly upon closing the game." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Main Booster Split View -->
        <Grid Grid.Row="2" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Detected Running Games Card -->
            <Border Grid.Column="0" CornerRadius="12" Padding="24" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE909;" Foreground="{StaticResource NXGAccentBrush}" FontSize="18"/>
                        <TextBlock Text="Running Games Detected" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{StaticResource NXGTextWhiteBrush}"/>
                    </StackPanel>

                    <!-- Games List -->
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DetectedGames, Mode=OneWay}" SelectionMode="None" Margin="0,10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" Margin="0,4" Background="{StaticResource NXGSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource NXGCardBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                            <FontIcon Glyph="&#xE7FC;" Foreground="{StaticResource NXGSuccessBrush}"/>
                                            <TextBlock Text="{Binding}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource NXGTextWhiteBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Trigger Boost" Click="BoostButton_Click" CommandParameter="{Binding}" Style="{StaticResource AccentButtonStyle}" CornerRadius="6" Padding="12,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="1" Text="No supported games detected. Launch a game or add its executable name to Custom Games below." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkDimBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Visibility="{x:Bind ViewModel.DetectedGamesEmptyVisibility, Mode=OneWay}"/>

                    <Button Grid.Row="2" Content="Scan for Running Games" Command="{x:Bind ViewModel.RefreshGamesCommand}" CornerRadius="8" Padding="16,8" HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Custom Configurations Card -->
            <Border Grid.Column="1" CornerRadius="12" Padding="24" Background="{StaticResource NXGCardBrush}" BorderBrush="{StaticResource NXGCardBorderBrush}" BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE713;" Foreground="{StaticResource NXGAccentBrush}" FontSize="18"/>
                        <TextBlock Text="Custom Configured Games" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{StaticResource NXGTextWhiteBrush}"/>
                    </StackPanel>

                    <!-- Add custom input box -->
                    <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" PlaceholderText="Enter filename (e.g. game.exe)..." Text="{x:Bind ViewModel.CustomGameInput, Mode=TwoWay}"/>
                        <Button Grid.Column="1" Content="Add" Command="{x:Bind ViewModel.AddCustomGameCommand}" CornerRadius="6" Padding="16,6" Style="{StaticResource AccentButtonStyle}"/>
                    </Grid>

                    <!-- Custom Games List -->
                    <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.CustomGames, Mode=OneWay}" SelectionMode="None" Margin="0,10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" Margin="0,4" Background="{StaticResource NXGSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource NXGCardBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource NXGInkBrush}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Click="RemoveCustomButton_Click" CommandParameter="{Binding}" Content="Delete" CornerRadius="6" Padding="12,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
