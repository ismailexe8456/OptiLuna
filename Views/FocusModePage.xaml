<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Dtrl.Views.FocusModePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Dtrl.Views"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Focus Mode" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource DtrlTextWhiteBrush}"/>

        <!-- Explanatory header panel -->
        <Border Grid.Row="1" CornerRadius="12" Padding="24" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE756;" Foreground="{StaticResource DtrlAccentBrush}" FontSize="24"/>
                    <TextBlock Text="Distraction-Free Focus Mode" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{StaticResource DtrlAccentBrightBrush}"/>
                </StackPanel>
                <TextBlock Text="Establish quiet hours by muting system notification banners and shutting down distracting social, browser, or game launcher processes." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Main Timer & Options Grid -->
        <Grid Grid.Row="2" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Timer controls panel -->
            <Border Grid.Column="0" CornerRadius="12" Padding="24" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Timer Circular Ring display -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <Grid Width="160" Height="160">
                            <ProgressRing Value="100" Width="150" Height="150" IsIndeterminate="False" Foreground="{StaticResource DtrlCardBorderBrush}"/>
                            <ProgressRing x:Name="ActiveProgressRing" Width="150" Height="150" IsIndeterminate="{x:Bind ViewModel.IsFocusActive, Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind ViewModel.TimeRemainingText, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="36" FontWeight="Bold" Foreground="{StaticResource DtrlTextWhiteBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Presets Selector -->
                    <StackPanel Grid.Row="1" Spacing="12">
                        <TextBlock Text="Duration Presets" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlTextWhiteBrush}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="25 Mins" Click="PresetButton_Click" CommandParameter="25" HorizontalAlignment="Stretch" CornerRadius="8" Padding="12,8"/>
                            <Button Grid.Column="1" Content="50 Mins" Click="PresetButton_Click" CommandParameter="50" HorizontalAlignment="Stretch" CornerRadius="8" Padding="12,8"/>
                            <Button Grid.Column="2" Content="90 Mins" Click="PresetButton_Click" CommandParameter="90" HorizontalAlignment="Stretch" CornerRadius="8" Padding="12,8"/>
                        </Grid>

                        <Slider Header="Custom Duration (minutes)" Minimum="5" Maximum="240" Value="{x:Bind ViewModel.DurationMinutes, Mode=TwoWay}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Start/Stop Button -->
                    <Button Grid.Row="2" Content="{x:Bind local:FocusModePage.GetButtonText(ViewModel.IsFocusActive), Mode=OneWay}" Command="{x:Bind ViewModel.ToggleFocusCommand}" Style="{StaticResource AccentButtonStyle}" CornerRadius="8" Padding="20,12" HorizontalAlignment="Stretch" FontSize="16" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- Settings / App list panel -->
            <Border Grid.Column="1" CornerRadius="12" Padding="24" Background="{StaticResource DtrlCardBrush}" BorderBrush="{StaticResource DtrlCardBorderBrush}" BorderThickness="1">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Feature Toggles -->
                    <StackPanel Grid.Row="0" Spacing="8">
                        <TextBlock Text="Configurations" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{StaticResource DtrlTextWhiteBrush}"/>
                        <ToggleSwitch Header="Mute Windows Notifications" IsOn="{x:Bind ViewModel.MuteNotifications, Mode=TwoWay}" IsEnabled="{x:Bind local:FocusModePage.Not(ViewModel.IsFocusActive), Mode=OneWay}"/>
                        <ToggleSwitch Header="Close Distraction Apps" IsOn="{x:Bind ViewModel.BlockDistractions, Mode=TwoWay}" IsEnabled="{x:Bind local:FocusModePage.Not(ViewModel.IsFocusActive), Mode=OneWay}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="{StaticResource DtrlCardBorderBrush}"/>

                    <!-- App list title -->
                    <TextBlock Grid.Row="2" Text="Blocklist Applications" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{StaticResource DtrlTextWhiteBrush}"/>

                    <!-- App List View -->
                    <Grid Grid.Row="3" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Add application input -->
                        <Grid Grid.Row="0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" PlaceholderText="Enter process name (e.g. steam)..." Text="{x:Bind ViewModel.NewBlockedAppInput, Mode=TwoWay}" IsEnabled="{x:Bind local:FocusModePage.Not(ViewModel.IsFocusActive), Mode=OneWay}"/>
                            <Button Grid.Column="1" Content="Block" Command="{x:Bind ViewModel.AddBlockedAppCommand}" CornerRadius="6" Padding="16,6" Style="{StaticResource AccentButtonStyle}" IsEnabled="{x:Bind local:FocusModePage.Not(ViewModel.IsFocusActive), Mode=OneWay}"/>
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.BlockedApps, Mode=OneWay}" SelectionMode="None" Margin="0,6">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="10" Margin="0,3" Background="{StaticResource DtrlSurfaceBrush}" BorderThickness="1" BorderBrush="{StaticResource DtrlCardBorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource DtrlInkBrush}" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Click="RemoveAppButton_Click" CommandParameter="{Binding}" Content="Remove" CornerRadius="6" Padding="12,4" IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsFocusInactive}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
